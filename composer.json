  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Atmostfear Entertainment",
      "homepage": "https://www.atmostfear-entertainment.com/aegis/"
    }
  ],
  "type": "wordpress-theme",
  "scripts": {
    "pot": "wp i18n make-pot ./ languages/aegis-child.pot --exclude='wp,wp-content,vendor,tests,node_modules,build'",
    "zip": "zip -r ../../aegis-child.zip . -x '*.git*' '*node_modules*' '*.DS_Store*' '*build*' 'package.json' 'composer.json' 'README.md'"
  },
  "minimum-stability": "dev"
}